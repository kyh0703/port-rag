# Required. Async SQLAlchemy URL for the port-dedicated Postgres (+pgvector).
# In docker-compose the host is `postgres`; locally use `localhost`.
DATABASE_URL=postgresql+asyncpg://port:port@postgres:5432/port

# Required only when EMBEDDER=openai.
OPENAI_API_KEY=

# "openai" (default) or "fake" (dev/test only, no API key needed).
EMBEDDER=fake

HTTP_PORT=8000

# Exposes Prometheus application metrics at /metrics.
METRICS_ENABLED=true

EMBEDDING_MODEL=text-embedding-3-small
EMBEDDING_DIM=1536
TOP_K_DEFAULT=5

# Optional. Enables Sentry reporting for unhandled FastAPI exceptions.
SENTRY_DSN=
