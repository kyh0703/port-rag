# Required. Async SQLAlchemy URL for the reg-dedicated Postgres (+pgvector).
# In docker-compose the host is `postgres`; locally use `localhost`.
DATABASE_URL=postgresql+asyncpg://reg:reg@postgres:5432/reg

# Required only when EMBEDDER=openai.
OPENAI_API_KEY=

# "openai" (default) or "fake" (dev/test only, no API key needed).
EMBEDDER=fake

GRPC_PORT=50051
HTTP_PORT=8000

EMBEDDING_MODEL=text-embedding-3-small
EMBEDDING_DIM=1536
TOP_K_DEFAULT=5

# Optional compose-only override. Default works from ../reg after merge.
CONTRACTS_GEN=../contracts/gen/python
